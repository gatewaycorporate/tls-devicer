{
  "name": "tls-devicer",
  "version": "0.2.7",
  "type": "module",
  "description": "TLS Intelligence Middleware for the FP-Devicer Intelligence Suite",
  "main": "./dist/main.js",
  "types": "./dist/main.d.ts",
  "exports": {
    ".": {
      "types": "./dist/main.d.ts",
      "import": "./dist/main.js",
      "default": "./dist/main.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --outDir dist",
    "test": "npx vitest run",
    "test:watch": "npx vitest watch",
    "test:coverage": "npx vitest run --coverage",
    "docs": "typedoc --out docs src/main.ts",
    "docs:watch": "typedoc --out docs src/main.ts --watch"
  },
  "keywords": [
    "tls",
    "ja4",
    "ja3",
    "fingerprinting",
    "middleware",
    "http2"
  ],
  "author": "Samuel Roux",
  "license": "BSL-1.0",
  "dependencies": {
    "devicer.js": "^1.6.1",
    "tlsh": "^1.0.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^18.19.130",
    "@vitest/coverage-v8": "^3.2.4",
    "better-sqlite3": "^12.8.0",
    "typedoc": "^0.28.17",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "peerDependencies": {
    "better-sqlite3": "^12.6.2",
    "ioredis": "^5.10.0",
    "pg": "^8.20.0"
  }
}
